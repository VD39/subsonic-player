            <div class="content">
              <h4>track-0</h4>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="trackCell trackOptions"><button class="centerItems buttonLink" draggable="false" type="button">
        <phpluscircle aria-hidden="true" class="icon" size="24" weight="regular"></phpluscircle><span class="clamp text visuallyHidden"> Add to queue </span>
      </button></div>
    <div class="trackCell trackOptions">
      <div>
        <track-play-pause-dropdown-item-stub trackid="track-0" type="track"></track-play-pause-dropdown-item-stub>
        <li class="centerItems dropdownItem"><button class="centerItems buttonLink centerAll fullWidth spaceBetween item spaceBetween item" draggable="false" type="button">
            <!--v-if--><span class="clamp text"> Add to queue </span>
          </button></li>
        <li class="centerItems dropdownItem"><button class="centerItems buttonLink centerAll fullWidth spaceBetween item spaceBetween item" draggable="false" type="button">
            <!--v-if--><span class="clamp text"> Add to playlist </span>
          </button></li>
        <li aria-hidden="true" class="divider"></li>
