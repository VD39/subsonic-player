// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`FileListItem > matches the snapshot 1`] = `
"<div class="lazyLoadContent trackRow">
  <div class="interactionWrapper" draggable="false">
    <div class="trackCell">
      <div>
        <track-play-pause-stub image="image-0" trackid="track-0" tracknumber="1" hideimage="false" large="false"></track-play-pause-stub>
